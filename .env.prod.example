# ── ENV PRODUKSI ERPCakra ─────────────────────────────────────────────────────
# Salin file ini ke `.env.prod`, isi nilai aslinya, lalu:
#   docker compose --env-file .env.prod -f compose.prod.yaml up -d
# JANGAN commit .env.prod ke git (berisi password).
# ──────────────────────────────────────────────────────────────────────────────

# Domain produksi. Site Frappe dibuat dengan nama ini, dan Caddy menerbitkan
# sertifikat HTTPS untuknya. DNS A-record domain ini HARUS sudah mengarah ke IP server.
SITE_NAME=erp.namadomainmu.com

# Email untuk Let's Encrypt (notifikasi & pemulihan sertifikat).
LETSENCRYPT_EMAIL=admin@namadomainmu.com

# Password root MariaDB (BUAT YANG KUAT — ini bukan default lagi).
DB_ROOT_PASS=GANTI_dengan_password_kuat

# Password admin (Administrator) login pertama kali.
ADMIN_PASS=GANTI_dengan_password_kuat

 "html": "<script>document.title = \"{{ frappe.utils.formatdate(doc.inquiry_date, 'yyMMdd') }} - {{ doc.name.replace('/', '') }} - {{ (doc.organization_name or doc.organization or '').replace('\"', '').replace('.', '') }}\";</script><style>@page { size: A4; margin: 12mm; } table.inq td, table.inq th { border:1px solid #999; padding:4px 7px; vertical-align:top; }</style>\n{% set office = frappe.get_doc(\"CMI Office\", doc.branch_office) if doc.branch_office and frappe.db.exists(\"CMI Office\", doc.branch_office) else (frappe.get_doc(\"CMI Office\", \"Surabaya\") if frappe.db.exists(\"CMI Office\", \"Surabaya\") else None) %}\n<div style=\"font-family: Arial, Helvetica, sans-serif; font-size:12px; color:#111; line-height:1.25;\">\n  <table style=\"width:100%; border-bottom:2px solid #333; padding-bottom:2px;\"><tr>\n    <td style=\"width:95px; vertical-align:middle;\"><img src=\"data:image/png;base64,\" style=\"width:85px;\"></td>\n    <td style=\"text-align:center; vertical-align:middle;\">\n      <div style=\"font-size:18px; font-weight:bold;\">PT CAKRAINDO MITRA INTERNASIONAL</div>\n      {% if office and office.phone %}<div style=\"font-size:11px; color:#333;\">Telp : {{ office.phone }}</div>{% endif %}\n    </td>\n    <td style=\"width:95px;\"></td>\n  </tr></table>\n  <table style=\"width:100%; margin-top:2px; margin-bottom:6px;\"><tr>\n    <td style=\"color:#1a6ea8; font-weight:bold; font-size:14px; vertical-align:top;\">{{ office.city if office else \"Surabaya\" }}, {{ frappe.utils.formatdate(doc.inquiry_date, \"MMM dd, yyyy\") }}</td>\n    <td style=\"text-align:right; vertical-align:top;\"><div style=\"color:#1a6ea8; font-weight:bold; font-size:14px;\">REF : {{ doc.name }}</div></td>\n  </tr></table>\n  <table class=\"inq\" style=\"width:100%; border-collapse:collapse; font-size:12px;\">\n    <thead><tr style=\"background:#e9e9e9; font-weight:bold;\">\n      <th style=\"width:32px; text-align:center;\">No</th>\n      <th style=\"width:245px; text-align:left;\">Deskripsi</th>\n      <th style=\"text-align:left;\">Item</th>\n    </tr></thead>\n    <tbody>\n      <tr><td style=\"text-align:center;\">1</td><td>Customer</td><td style=\"white-space:pre-line;\">{{ doc.organization_name or doc.organization or \"\" }}</td></tr>\n      <tr><td style=\"text-align:center;\">2</td><td>Shipper / Consignee</td><td style=\"white-space:pre-line;\">{{ doc.shipper_consignee or \"\" }}</td></tr>\n      <tr><td style=\"text-align:center;\">3</td><td>Business Unit</td><td>{{ doc.business_unit or \"\" }}</td></tr>\n      <tr><td style=\"text-align:center;\">4</td><td>Type Inquiry</td><td>{{ doc.type_inquiry | map(attribute='type') | join('; ') }}</td></tr>\n      <tr><td style=\"text-align:center;\">5</td><td>Transportation Mode</td><td>{{ doc.transportation_mode or \"\" }}</td></tr>\n      <tr><td style=\"text-align:center;\">6</td><td>Incoterms</td><td>{{ doc.incoterms or \"\" }}</td></tr>\n      <tr><td style=\"text-align:center;\">7</td><td>Qty / Volume</td><td>{{ doc.qty_volume or \"\" }}</td></tr>\n      <tr><td style=\"text-align:center;\">8</td><td>Port/Point Of Loading / Destination (Detail Address)</td><td style=\"white-space:pre-line;\">{{ doc.port_pol_destination_detail_address or \"\" }}</td></tr>\n      <tr><td style=\"text-align:center;\">9</td><td>Origin</td><td style=\"white-space:pre-line;\">{{ doc.origin or \"\" }}</td></tr>\n      <tr><td style=\"text-align:center;\">10</td><td>Destination</td><td style=\"white-space:pre-line;\">{{ doc.destination or \"\" }}</td></tr>\n      <tr><td style=\"text-align:center;\">11</td><td>Cargo Commodity / Type / HS Code</td><td style=\"white-space:pre-line;\">{{ doc.cargo_commodity or \"\" }}</td></tr>\n      <tr><td style=\"text-align:center;\">12</td><td>Cargo Weight (KG) / Volume / Packaging</td><td>{{ doc.cargo_weight or \"\" }}{% if doc.cargo_packaging %}{% if doc.cargo_weight %} / {% endif %}{{ doc.cargo_packaging }}{% endif %}</td></tr>\n      <tr><td style=\"text-align:center;\">13</td><td>Status Cargo</td><td>{{ doc.status_cargo or \"\" }}</td></tr>\n      <tr><td style=\"text-align:center;\">14</td><td>Shipment Date</td><td>{{ frappe.utils.formatdate(doc.date_shipment, \"MMM dd, yyyy\") if doc.date_shipment else \"\" }}</td></tr>\n      <tr><td style=\"text-align:center;\">15</td><td>Remarks</td><td style=\"white-space:pre-line;\">{{ doc.remarks or \"\" }}</td></tr>\n    </tbody>\n  </table>\n  <div style=\"margin-top:16px; font-weight:bold;\">Request by {{ frappe.db.get_value('User', doc.inquiry_owner or doc.owner, 'full_name') or '' }}</div>\n</div>",

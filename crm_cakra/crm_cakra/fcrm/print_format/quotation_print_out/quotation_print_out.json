 "font_size": 14,
 "html": "<script>document.title = \"{{ frappe.utils.formatdate(doc.date, 'yyMMdd') }} - {{ doc.name.replace('/', '') }} - {{ (doc.account_name or doc.account or '').replace('\"', '').replace('.', '') }}\";</script><style>@page { size: A4; margin: 12mm; }</style>\r\n{% set office = frappe.get_doc(\"CMI Office\", doc.branch_office) if doc.branch_office and frappe.db.exists(\"CMI Office\", doc.branch_office) else (frappe.get_doc(\"CMI Office\", \"Surabaya\") if frappe.db.exists(\"CMI Office\", \"Surabaya\") else None) %}\r\n{% set job_service = frappe.db.get_value(\"CRM Inquiry\", doc.inquiry, \"job_service\") if doc.inquiry else \"\" %}\r\n<div style=\"font-family: Arial, Helvetica, sans-serif; font-size:12px; color:#111; line-height:1.25;\">\r\n\r\n  <table style=\"width:100%; border-bottom:2px solid #333; padding-bottom:2px;\"><tr>\r\n    <td style=\"width:95px; vertical-align:middle;\"><img src=\"data:image/png;base64,\" style=\"width:85px;\"></td>\r\n    <td style=\"text-align:center; vertical-align:middle;\">\r\n      <div style=\"font-size:18px; font-weight:bold;\">PT CAKRAINDO MITRA INTERNASIONAL</div>\r\n      <div style=\"font-size:11px; color:#333; white-space:pre-line;\">{{ office.address if office else \"\" }}</div>\r\n      {% if office and office.phone %}<div style=\"font-size:11px; color:#333;\">Telp : {{ office.phone }}</div>{% endif %}\r\n    </td>\r\n    <td style=\"width:95px;\"></td>\r\n  </tr></table>\r\n\r\n  <table style=\"width:100%; margin-top:2px;\"><tr>\r\n    <td style=\"color:#1a6ea8; font-weight:bold; font-size:14px; vertical-align:top;\">{{ office.city if office else \"Surabaya\" }}, {{ frappe.utils.formatdate(doc.date, \"MMM dd, yyyy\") }}</td>\r\n    <td style=\"text-align:right; vertical-align:top;\">\r\n      <div style=\"color:#1a6ea8; font-weight:bold; font-size:14px;\">REF : {{ doc.name }}</div>\r\n      <div style=\"font-size:11px; color:#333;\">DOC NUMBER: F-BDM-02-01</div>\r\n    </td>\r\n  </tr></table>\r\n  <hr style=\"border:none; border-top:1px solid #ccc; margin:2px 0;\">\r\n\r\n  <div style=\"font-weight:bold;\">{{ doc.account_name or \"\" }}</div>\r\n  {% if doc.attention %}<div style=\"font-weight:bold;\">Attn : {{ doc.attention }}</div>{% endif %}\r\n  <p style=\"margin:5px 0;\">We are pleased to quote our best offer as follows:</p>\r\n\r\n  <table style=\"width:100%; margin-bottom:5px; border-collapse:collapse;\">\r\n    {% if job_service %}<tr><td style=\"width:150px; padding:5px !important; line-height:1.05 !important;\">Job Service</td><td style=\"width:12px; padding:5px !important; line-height:1.05 !important;\">:</td><td style=\"padding:5px !important; line-height:1.05 !important;\">{{ job_service }}</td></tr>{% endif %}\r\n    {% if doc.packaging %}<tr><td style=\"padding:5px !important; line-height:1.05 !important;\">Packaging</td><td style=\"padding:5px !important; line-height:1.05 !important;\">:</td><td style=\"padding:5px !important; line-height:1.05 !important;\">{{ doc.packaging }}</td></tr>{% endif %}\r\n    {% if doc.cargo %}<tr><td style=\"padding:5px !important; line-height:1.05 !important;\">Cargo</td><td style=\"padding:5px !important; line-height:1.05 !important;\">:</td><td style=\"padding:5px !important; line-height:1.05 !important;\">{{ doc.cargo }}</td></tr>{% endif %}\r\n    {% if doc.loading %}<tr><td style=\"padding:5px !important; line-height:1.05 !important;\">Loading</td><td style=\"padding:5px !important; line-height:1.05 !important;\">:</td><td style=\"padding:5px !important; line-height:1.05 !important;\">{{ doc.loading }}</td></tr>{% endif %}\r\n    {% if doc.unloading %}<tr><td style=\"padding:5px !important; line-height:1.05 !important;\">Unloading</td><td style=\"padding:5px !important; line-height:1.05 !important;\">:</td><td style=\"padding:5px !important; line-height:1.05 !important;\">{{ doc.unloading }}</td></tr>{% endif %}\r\n  </table>\r\n\r\n  {% if doc.subject %}<div style=\"background:#e9e9e9; padding:2px 6px; font-weight:bold; margin-bottom:10px;\">{{ doc.subject }}</div>{% endif %}\r\n\r\n  <table style=\"width:100%; border-collapse:collapse; margin-bottom:2px;\">\r\n    <thead><tr style=\"background:#e9e9e9;\">\r\n      <th style=\"text-align:left; color:#1a6ea8; padding:1px 8px; border-bottom:1px solid #ccc;\">Item &amp; Description</th>\r\n      <th style=\"text-align:right; color:#1a6ea8; padding:1px 8px; border-bottom:1px solid #ccc; width:170px;\">Amount</th>\r\n    </tr></thead>\r\n    <tbody>\r\n      {% for p in doc.products %}\r\n      {% set iname = frappe.db.get_value(\"CRM Product\", p.product_code, \"product_name\") if p.product_code else \"\" %}\r\n      <tr style=\"border-bottom:1px solid #eee;\">\r\n        <td style=\"padding:1px 8px; vertical-align:top;\"><span style=\"font-weight:bold;\">{{ iname or p.product_code or \"\" }}</span>{% if p.product_name %}<div style=\"font-size:11px; color:#444; white-space:pre-line;\">{{ p.product_name }}</div>{% endif %}</td>\r\n        <td style=\"padding:1px 8px; text-align:right; vertical-align:top;\">{{ p.currency or doc.currency }} {{ \"{:,.2f}\".format((p.qty or 0) * (p.price or 0)) }}</td>\r\n      </tr>\r\n      {% endfor %}\r\n    </tbody>\r\n  </table>\r\n\r\n  {% if doc.additional1_item or doc.additional1_amount %}<div style=\"background:#e9e9e9; padding:3px 8px; font-weight:bold; margin-bottom:0;\">{{ doc.additional1_title }}</div><div style=\"display:flex; font-size:11px; margin-bottom:5px; padding:0 8px;\"><div style=\"flex:1; white-space:pre-line;\">{{ doc.additional1_item or \"\" }}</div><div style=\"width:38%; text-align:left; white-space:pre-line;\">{{ doc.additional1_amount or \"\" }}</div></div>{% endif %}\r\n  {% if doc.additional2_item or doc.additional2_amount %}<div style=\"background:#e9e9e9; padding:3px 8px; font-weight:bold; margin-bottom:0;\">{{ doc.additional2_title }}</div><div style=\"display:flex; font-size:11px; margin-bottom:5px; padding:0 8px;\"><div style=\"flex:1; white-space:pre-line;\">{{ doc.additional2_item or \"\" }}</div><div style=\"width:38%; text-align:left; white-space:pre-line;\">{{ doc.additional2_amount or \"\" }}</div></div>{% endif %}  \r\n\r\n  {% if doc.tac or doc.tac_detail %}\r\n  <div style=\"margin-top:5px;\">\r\n    <div style=\"background:#e9e9e9; padding:3px 8px; font-weight:bold; margin-bottom:2px;\">{{ doc.tac or \"Terms &amp; Conditions\" }}</div>\r\n    {% if doc.tac_detail %}<div style=\"font-size:11px; white-space:pre-line; padding:0 8px;\">{{ doc.tac_detail }}</div>{% endif %}\r\n  </div>\r\n  {% endif %}\r\n\r\n  <table style=\"width:100%; margin-top:5px; border-collapse:collapse;\">\r\n    {% if doc.validity_date %}<tr><td style=\"width:150px; padding:0 !important; line-height:1.05 !important;\">Validity</td><td style=\"width:12px; padding:0 !important; line-height:1.05 !important;\">:</td><td style=\"padding:0 !important; line-height:1.05 !important;\">{{ frappe.utils.formatdate(doc.validity_date, \"dd MMMM yyyy\") }}</td></tr>{% endif %}\r\n    {% if doc.payterm %}<tr><td style=\"padding:0 !important; line-height:1.05 !important;\">Payment Term</td><td style=\"padding:0 !important; line-height:1.05 !important;\">:</td><td style=\"padding:0 !important; line-height:1.25 !important; white-space:pre-line;\">{{ doc.payterm }}</td></tr>{% endif %}\r\n  </table>\r\n\r\n  <p style=\"margin:5px 0;\">Should you need further details or information, please do not hesitate to contact us, Thank you.</p>\r\n\r\n  <table style=\"width:100%; margin-top:5px;\"><tr>\r\n    <td style=\"width:50%; vertical-align:top;\">Regards,<br><b>PT. CAKRAINDO MITRA INTERNASIONAL</b><br><img src=\"data:image/png;base64,\" style=\"width:95px; margin-top:4px;\"><br><b>{{ frappe.db.get_value('User', doc.printed_by or doc.owner, 'full_name') or '' }}</b></td>\r\n    <td style=\"width:50%; vertical-align:top;\">Approved By.<br><b>{{ doc.account_name or doc.account or '' }}</b><br><span style=\"display:inline-block; width:95px; height:90px; margin-top:4px;\"></span><br>{% if doc.attention %}Attn : {{ doc.attention }}{% endif %}</td>\r\n  </tr></table>\r\n\r\n</div>",
